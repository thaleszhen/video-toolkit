# Database
DATABASE_URL=sqlite:///./demand_radar.db
# 或使用 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/demand_radar

# API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Reddit API (可选)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=DemandRadar/0.1

# Vector DB (可选)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis (可选)
REDIS_URL=redis://localhost:6379/0

# App
DEBUG=true
